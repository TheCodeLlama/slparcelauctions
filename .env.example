# SLPA local development environment.
# Copy this file to .env and adjust as needed. The defaults match docker-compose.yml.

# ----- PostgreSQL -----
POSTGRES_DB=slpa
POSTGRES_USER=slpa
POSTGRES_PASSWORD=slpa
POSTGRES_PORT=5432

# ----- Redis -----
REDIS_PORT=6379

# ----- Backend (Spring Boot) -----
BACKEND_PORT=8080
# Origin allowed by Spring Security CORS. Browser requests from this origin
# can hit /api/**. Inside the docker network, frontend SSR talks to the
# backend via http://backend:8080 instead of this URL.
CORS_ALLOWED_ORIGIN=http://localhost:3000

# ----- Frontend (Next.js) -----
FRONTEND_PORT=3000
# Public URL the browser uses to reach the backend. NOT the in-network URL.
NEXT_PUBLIC_API_URL=http://localhost:8080
