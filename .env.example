# =============================================================================
# SLParcels local development environment
#
# These defaults are for LOCAL DEVELOPMENT ONLY. Do not reuse them in staging
# or production. Every value tagged "# DEV ONLY" must be rotated to a
# unique, high-entropy secret in the real .env for that environment, along
# with any new _PASSWORD, _SECRET, _TOKEN, or public URL added later.
#
# Production deployment notes are in README.md → "Production deployment".
# =============================================================================

# Copy this file to .env and adjust as needed. The defaults match docker-compose.yml.

# ----- PostgreSQL -----
POSTGRES_DB=slpa
POSTGRES_USER=slpa
POSTGRES_PASSWORD=slpa            # DEV ONLY — rotate before any non-local deployment
POSTGRES_PORT=5432

# ----- Redis -----
REDIS_PORT=6379

# ----- MinIO (S3-compatible object storage, dev) -----
MINIO_ROOT_USER=slpa-dev-key
MINIO_ROOT_PASSWORD=slpa-dev-secret   # DEV ONLY — rotate before any non-local deployment
MINIO_S3_PORT=9000
MINIO_CONSOLE_PORT=9001

# ----- Backend (Spring Boot) -----
BACKEND_PORT=8080
# Origin allowed by Spring Security CORS. Browser requests from this origin
# can hit /api/**. Inside the docker network, frontend SSR talks to the
# backend via http://backend:8080 instead of this URL.
CORS_ALLOWED_ORIGIN=http://localhost:3000   # DEV ONLY — set to your real frontend origin in prod

# ----- Frontend (Next.js) -----
FRONTEND_PORT=3000
# Public URL the browser uses to reach the backend. NOT the in-network URL.
NEXT_PUBLIC_API_URL=http://localhost:8080   # DEV ONLY — set to your real backend URL in prod

# ----- Bot worker health ports -----
# Each bot container's ASP.NET health endpoint listens on container port 8081.
# Map each to a distinct host port so multiple workers can run side-by-side.
# Curl from the host: `curl http://localhost:${BOT1_HEALTH_PORT}/health`.
BOT1_HEALTH_PORT=8081
BOT2_HEALTH_PORT=8082

# ----- Bot + Escrow integration (Epic 06) -----
# Real SL UUID of the SLPAEscrow Resident sentinel account. The backend
# validates every bot VERIFY callback's authBuyerId against this value.
# Dev default below matches the BotStartupValidator dev-placeholder gate.
SLPA_PRIMARY_ESCROW_UUID=00000000-0000-0000-0000-000000000099   # DEV ONLY — set to real SLPAEscrow UUID in non-dev

# Bearer token that gates /api/v1/bot/** endpoints. Bot workers send this
# in their Authorization header on every claim / verify / monitor call.
# BotStartupValidator fails fast on non-dev profiles if this is blank,
# equals this dev placeholder, or is shorter than 16 characters.
SLPA_BOT_SHARED_SECRET=dev-bot-shared-secret   # DEV ONLY — rotate before any non-local deployment

# Optional monitor + sweep timing overrides. Defaults from application.yml apply
# if unset. Useful to shrink for integration tests; restore defaults before commit.
# SLPA_BOT_MONITOR_AUCTION_INTERVAL=PT30M
# SLPA_BOT_MONITOR_ESCROW_INTERVAL=PT15M
# SLPA_BOT_TASK_IN_PROGRESS_TIMEOUT=PT20M
# SLPA_BOT_TASK_TIMEOUT_CHECK_INTERVAL=PT15M
