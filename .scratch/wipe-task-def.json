{
  "family": "slpa-prod-db-wipe",
  "executionRoleArn": "arn:aws:iam::486208158127:role/slpa-prod-backend-task-execution-role",
  "taskRoleArn": "arn:aws:iam::486208158127:role/slpa-prod-backend-task-role",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "psql",
      "image": "public.ecr.aws/docker/library/postgres:16",
      "essential": true,
      "command": [
        "psql",
        "-h", "slpa-prod-postgres.celewqkic6r2.us-east-1.rds.amazonaws.com",
        "-U", "slpa",
        "-d", "slpa",
        "-c", "DROP SCHEMA public CASCADE; CREATE SCHEMA public;"
      ],
      "secrets": [
        {
          "name": "PGPASSWORD",
          "valueFrom": "arn:aws:ssm:us-east-1:486208158127:parameter/slpa/prod/rds/password"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/aws/ecs/slpa-backend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "db-wipe"
        }
      }
    }
  ]
}
