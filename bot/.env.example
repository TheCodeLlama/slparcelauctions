# bot/.env.example
# Copy to bot/.env.bot-1 (or .env.bot-N) and replace placeholders.
# Never commit the filled file - .env.bot-* is in .gitignore.

Bot__Username=First Last
Bot__Password=
# The SL avatar UUID of this bot account. Must be set per-instance.
Bot__BotUuid=00000000-0000-0000-0000-000000000000
Bot__StartLocation=last
# Must match slpa.bot.shared-secret on the backend (SLPA_BOT_SHARED_SECRET env).
Backend__SharedSecret=dev-bot-shared-secret
