FROM node:22-alpine

WORKDIR /app

# Install deps before copying the rest of the source so the layer cache survives source edits.
COPY package.json package-lock.json ./
RUN npm ci

# Source is bind-mounted in compose; this COPY only seeds an initial container build.
COPY . .

EXPOSE 3000

# WATCHPACK_POLLING enables file watching when the source is bind-mounted from a Windows host
# (inotify events don't reliably propagate across the WSL2 boundary).
ENV WATCHPACK_POLLING=true
ENV CHOKIDAR_USEPOLLING=true

CMD ["npm", "run", "dev", "--", "--hostname", "0.0.0.0"]
